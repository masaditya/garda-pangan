---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { EventHero } from '#/components/event-hero'
import { EventList } from '#/components/event-list'
import { fetchStrapiSingle } from '#/lib/strapi/client'
import { getEvents } from '#/lib/strapi/events'

type EventPageData = {
  heroTitle: string
  heroDescription: string
  heroBackground: any
}

let pageData: EventPageData = {
  heroTitle: 'Our Events',
  heroDescription:
    'Garda Pangan bermula dari pergerakan komunitas kecil yang berkembang jadi sesuatu yang memberikan manfaat lebih.',
  heroBackground: null,
}

let eventsData: any[] = []

try {
  const pageResponse = await fetchStrapiSingle<EventPageData>('api/event-page', {
    populate: '*',
  })
  if (pageResponse?.data) {
    pageData = pageResponse.data
  }
} catch (error) {
  console.error('Failed to fetch event page data:', error)
}

eventsData = await getEvents()

// Sort events by date descending by default
eventsData.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
---

<BaseLayout
  title={`${pageData.heroTitle} - Garda Pangan`}
  description={pageData.heroDescription}
  canonicalPath="/event"
>
  <main class="garda-main bg-[#f4fbf6] overflow-hidden">
    <EventHero
      title={pageData.heroTitle}
      description={pageData.heroDescription}
      backgroundImage={pageData.heroBackground}
    />
    
    <EventList client:load initialEvents={eventsData} />
  </main>
</BaseLayout>

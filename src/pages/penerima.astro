---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { BeneficiarySection } from '#/components/beneficiary-section'
import { normalizeStrapiMediaUrl } from '#/lib/strapi/client'

const API_URL = 'https://promising-freedom-82afaec97e.strapiapp.com/api/penerima-page?populate=*'
const response = await fetch(API_URL).catch(() => null)
const payload = response ? await response.json() : { data: null }
const data = payload?.data

const bgImage = normalizeStrapiMediaUrl(data?.heroBackground?.url) || '/garda-hero-reference.png'
---

<BaseLayout 
  title="Penerima Bantuan - Garda Pangan"
  description="Penerima manfaat utama dari distribusi makanan Garda Pangan."
  canonicalPath="/penerima"
>
  <main class="relative isolate min-h-screen">
    <div
      class="absolute inset-0 -z-20 bg-cover bg-fixed bg-center"
      style={`background-image: url(${bgImage})`}
    >
    </div>
    <div class="absolute inset-0 -z-10 bg-[#0C381E]/80 mix-blend-multiply"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-[50vh] bg-linear-to-b from-[#0C381E]/60 to-transparent">
    </div>

    <div class="relative z-10 w-full">
      <BeneficiarySection client:load data={data} />
    </div>
  </main>
</BaseLayout>

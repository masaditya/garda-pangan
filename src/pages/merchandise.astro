---
import { MerchandiseCatalog } from '../components/merchandise-catalog'
import { MerchandiseHeroSection } from '../components/merchandise-hero-section'
import { normalizeStrapiMediaUrl } from '../lib/strapi/client'
import {
  buildMerchandiseCategoryCounts,
  getMerchandiseCategories,
  getMerchandises,
  mapMerchandiseToItem,
} from '../lib/strapi/merchandise'
import { getMerchandisePage } from '../lib/strapi/pages'
import BaseLayout from '../layouts/BaseLayout.astro'

const [payload, categories, merchandises] = await Promise.all([
  getMerchandisePage().catch(() => ({ data: null })),
  getMerchandiseCategories().catch(() => []),
  getMerchandises().catch(() => []),
])

const data = payload.data
const bgImage =
  normalizeStrapiMediaUrl(data?.heroBackground?.url) || '/garda-hero-reference.png'
const products = merchandises.map(mapMerchandiseToItem)
const categoryCounts = buildMerchandiseCategoryCounts(categories, merchandises)
---

<BaseLayout
  title="Merchandise | Garda Pangan"
  description="Dukung gerakan Garda Pangan melalui merchandise resmi."
  canonicalPath="/merchandise"
>
  <main class="relative isolate min-h-screen">
    <div
      class="absolute inset-0 -z-20 bg-cover bg-fixed bg-center"
      style={`background-image: url(${bgImage})`}
    >
    </div>
    <div class="absolute inset-0 -z-10 bg-[#0C381E]/80 mix-blend-multiply"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-[50vh] bg-gradient-to-b from-[#0C381E]/60 to-transparent">
    </div>

    <div class="relative z-10 w-full">
      <MerchandiseHeroSection data={data} />
      <MerchandiseCatalog
        client:load
        products={products}
        categories={categoryCounts}
      />
    </div>
  </main>
</BaseLayout>

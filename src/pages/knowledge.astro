---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { EventHero } from '#/components/event-hero'
import { KnowledgeList } from '#/components/knowledge-list'
import { fetchStrapiSingle, fetchAllStrapiPages } from '#/lib/strapi/client'

type KnowledgePageData = {
  heroTitle: string
  heroDescription?: string
  heroBackground: any
}

let pageData: KnowledgePageData = {
  heroTitle: 'Knowledge & Insights',
  heroDescription: '',
  heroBackground: null,
}

let knowledgesData: any[] = []

try {
  const pageResponse = await fetchStrapiSingle<KnowledgePageData>('api/knowledge-page', {
    populate: '*',
  })
  if (pageResponse?.data) {
    pageData = pageResponse.data
  }
} catch (error) {
  console.error('Failed to fetch knowledge page data:', error)
}

try {
  const knowledgesResponse = await fetchAllStrapiPages<any>('api/knowledges', {
    populate: '*',
  })
  knowledgesData = knowledgesResponse || []
} catch (error) {
  console.error('Failed to fetch knowledges:', error)
}

// Sort by date descending
if (knowledgesData.length > 0) {
  knowledgesData.sort((a, b) => new Date(b.date || b.createdAt || 0).getTime() - new Date(a.date || a.createdAt || 0).getTime())
}
---

<BaseLayout
  title={`${pageData.heroTitle} - Garda Pangan`}
  description={pageData.heroDescription || 'Knowledge and Insights from Garda Pangan'}
  canonicalPath="/knowledge"
>
  <main class="garda-main bg-[#f4fbf6] overflow-hidden">
    <EventHero
      title={pageData.heroTitle}
      description={pageData.heroDescription || ''}
      backgroundImage={pageData.heroBackground}
    />
    
    <KnowledgeList client:load initialKnowledges={knowledgesData} />
  </main>
</BaseLayout>

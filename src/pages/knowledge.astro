---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { EventHero } from '#/components/event-hero'
import { KnowledgeList } from '#/components/knowledge-list'
import type { KnowledgeListLabels } from '#/components/knowledge-list'
import { getCategories } from '#/lib/strapi/categories'
import { getKnowledgePage } from '#/lib/strapi/knowledge-page'
import { getArticlesForKnowledge } from '#/lib/strapi/articles'
import { mapArticleToKnowledgeItem } from '#/lib/strapi/knowledge'
import { normalizeStrapiMediaUrl } from '#/lib/strapi/client'

const [pageResponse, categories, articles] = await Promise.all([
  getKnowledgePage().catch(() => ({ data: null })),
  getCategories().catch(() => []),
  getArticlesForKnowledge().catch(() => []),
])

const pageData = pageResponse.data

const labels: KnowledgeListLabels = {
  searchPlaceholder:
    pageData?.searchPlaceholder ?? 'Cari Knowledge & Insights',
  categoryFilterLabel: pageData?.categoryFilterLabel ?? 'Kategori',
  filterAllLabel: pageData?.filterAllLabel ?? 'Tampilkan Semua',
  sortNewestLabel: pageData?.sortNewestLabel ?? 'Terbaru',
  sortOldestLabel: 'Terlama',
  searchSubmitLabel: pageData?.searchSubmitLabel ?? 'Search',
  paginationPrevLabel: pageData?.paginationPrevLabel ?? 'Previous',
  paginationNextLabel: pageData?.paginationNextLabel ?? 'Next',
  emptyListMessage:
    pageData?.emptyListMessage ??
    'Tidak ada artikel yang cocok dengan filter Anda.',
}

const knowledgeItems = articles.map(mapArticleToKnowledgeItem)
const heroBackground = normalizeStrapiMediaUrl(pageData?.heroBackground?.url)
---

<BaseLayout
  title={`${pageData?.heroTitle ?? 'Knowledge & Insights'} - Garda Pangan`}
  description={pageData?.heroSubtitle ?? 'Knowledge and Insights from Garda Pangan'}
  canonicalPath="/knowledge"
>
  <main class="garda-main bg-[#f4fbf6] overflow-hidden">
    <EventHero
      client:load
      title={pageData?.heroTitle ?? 'Knowledge & Insights'}
      description={pageData?.heroSubtitle ?? ''}
      backgroundImage={heroBackground}
    />

    <KnowledgeList
      client:load
      initialKnowledges={knowledgeItems}
      categories={categories.map((category) => ({
        name: category.name,
        slug: category.slug,
      }))}
      labels={labels}
    />
  </main>
</BaseLayout>

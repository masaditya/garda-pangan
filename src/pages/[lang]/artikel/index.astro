---
import { ArticleCard } from '#/components/article-card'
import { getPublishedArticles } from '#/lib/strapi/articles'
import BaseLayout from '#/layouts/BaseLayout.astro'
import {
  getLangStaticPaths,
  getMessages,
  localizedPath,
  resolveLocale,
} from '#/lib/i18n'

export function getStaticPaths() {
  return getLangStaticPaths()
}

const locale = resolveLocale(Astro.params.lang)
const messages = getMessages(locale)
const articles = await getPublishedArticles({ locale })
---

<BaseLayout
  locale={locale}
  title={messages.artikel.pageTitle}
  description={messages.artikel.pageDescription}
  canonicalPath={localizedPath('/artikel', locale)}
>
  <main class="bg-garda-paper">
    <section class="px-4 pb-16 pt-36 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-[1240px]">
        <div class="max-w-3xl">
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-garda-forest">
            {messages.artikel.heroTitle}
          </p>
          <h1 class="font-serif mt-4 text-5xl tracking-tight text-garda-ink sm:text-6xl">
            {messages.artikel.heroDescription}
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-garda-ink-soft">
            {messages.artikel.heroSubtitle}
          </p>
        </div>

        {
          articles.length > 0 ? (
            <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {articles.map((article) => (
                <ArticleCard article={article} locale={locale} />
              ))}
            </div>
          ) : (
            <div class="mt-12 rounded-[2rem] bg-white p-8 text-garda-ink-soft">
              {messages.artikel.emptyState}
            </div>
          )
        }
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { VolunteerSection } from '#/components/volunteer-section'
import {
  getLangStaticPaths,
  getMessages,
  localizedPath,
  resolveLocale,
} from '#/lib/i18n'

export function getStaticPaths() {
  return getLangStaticPaths()
}

const locale = resolveLocale(Astro.params.lang)
const messages = getMessages(locale)
const bgImage =
  'https://images.unsplash.com/photo-1593113598332-cd288d649433?q=80&w=2070&auto=format&fit=crop'
---

<BaseLayout
  locale={locale}
  title={messages.volunteer.pageTitle}
  description={messages.volunteer.pageDescription}
  canonicalPath={localizedPath('/relawan', locale)}
>
  <main class="relative isolate min-h-screen">
    <div
      class="absolute inset-0 -z-20 bg-cover bg-fixed bg-center"
      style={`background-image: url(${bgImage})`}
    >
    </div>
    <div class="absolute inset-0 -z-10 bg-[#0C381E]/75 mix-blend-multiply"></div>
    <div
      class="absolute inset-x-0 top-0 -z-10 h-[50vh] bg-linear-to-b from-[#0C381E]/60 to-transparent"
    >
    </div>

    <div class="relative z-10 w-full">
      <VolunteerSection
        client:load
        titleLine1={messages.volunteer.titleLine1}
        titleLine2={messages.volunteer.titleLine2}
        description={messages.volunteer.description}
        cta={messages.volunteer.cta}
      />
    </div>
  </main>
</BaseLayout>

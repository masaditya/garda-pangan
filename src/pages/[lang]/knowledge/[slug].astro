---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { KnowledgeDetail } from '#/components/knowledge-detail'
import {
  getLangStaticPaths,
  getMessages,
  localizedPath,
  resolveLocale,
} from '#/lib/i18n'
import {
  getArticleSlugsForPaths,
  getKnowledgeArticleBySlug,
} from '#/lib/strapi/articles'
import {
  formatKnowledgeArticleDate,
  getArticleCarouselImages,
  getArticleImageCaption,
} from '#/lib/strapi/knowledge'
import { marked } from 'marked'

export async function getStaticPaths() {
  const [idSlugs, enSlugs] = await Promise.all([
    getArticleSlugsForPaths({ locale: 'id' }),
    getArticleSlugsForPaths({ locale: 'en' }),
  ])

  return [
    ...idSlugs.map((slug) => ({ params: { lang: 'id', slug } })),
    ...enSlugs.map((slug) => ({ params: { lang: 'en', slug } })),
  ]
}

const locale = resolveLocale(Astro.params.lang)
const messages = getMessages(locale)

const resolvedArticle = await getKnowledgeArticleBySlug(
  Astro.params.slug ?? '',
  { locale },
).catch(() => null)

if (!resolvedArticle) {
  return Astro.redirect(localizedPath('/knowledge', locale))
}

const images = getArticleCarouselImages(resolvedArticle)
const formattedDate = formatKnowledgeArticleDate(
  resolvedArticle.publishedAt ?? resolvedArticle.createdAt,
  locale,
)
const parsedContent = resolvedArticle.content
  ? await marked.parse(resolvedArticle.content)
  : resolvedArticle.description
    ? `<p>${resolvedArticle.description}</p>`
    : ''
const articleUrl = new URL(
  localizedPath(`/knowledge/${resolvedArticle.slug}`, locale),
  Astro.url.origin,
).toString()
const tags = resolvedArticle.category?.name ? [resolvedArticle.category.name] : []
const caption = getArticleImageCaption(
  resolvedArticle,
  messages.common.imageCourtesy,
)
const coverUrl = images[0]
---

<BaseLayout
  locale={locale}
  title={`${resolvedArticle.title} | ${messages.meta.titleSuffix}`}
  description={resolvedArticle.description ?? messages.knowledge.pageDescription}
  canonicalPath={localizedPath(`/knowledge/${resolvedArticle.slug}`, locale)}
  ogImage={coverUrl}
>
  <main class="min-h-screen bg-white">
    <KnowledgeDetail
      client:load
      title={resolvedArticle.title}
      authorName={resolvedArticle.author?.name ?? messages.meta.titleSuffix}
      date={formattedDate}
      images={images}
      tags={tags}
      parsedContent={parsedContent}
      articleUrl={articleUrl}
      caption={caption}
    />
  </main>
</BaseLayout>

---
import { MerchandiseCatalog } from '#/components/merchandise-catalog'
import { MerchandiseHeroSection } from '#/components/merchandise-hero-section'
import BaseLayout from '#/layouts/BaseLayout.astro'
import {
  getLangStaticPaths,
  getMessages,
  localizedPath,
  resolveLocale,
} from '#/lib/i18n'
import { normalizeStrapiMediaUrl } from '#/lib/strapi/client'
import {
  buildMerchandiseCategoryCounts,
  getMerchandiseCategories,
  getMerchandises,
  mapMerchandiseToItem,
} from '#/lib/strapi/merchandise'
import { getMerchandisePage } from '#/lib/strapi/pages'

export function getStaticPaths() {
  return getLangStaticPaths()
}

const locale = resolveLocale(Astro.params.lang)
const messages = getMessages(locale)

const [payload, categories, merchandises] = await Promise.all([
  getMerchandisePage({ locale }),
  getMerchandiseCategories({ locale }).catch(() => []),
  getMerchandises({ locale }).catch(() => []),
])

const data = payload.data
const bgImage =
  normalizeStrapiMediaUrl(data?.heroBackground?.url) || '/garda-hero-reference.png'
const products = merchandises.map((item) => mapMerchandiseToItem(item, locale))
const categoryCounts = buildMerchandiseCategoryCounts(categories, merchandises)

const filterLabels = {
  filterTitle: messages.merchandise.filterTitle,
  appliedCategoriesLabel: messages.merchandise.appliedCategoriesLabel,
  categoryListLabel: messages.merchandise.categoryListLabel,
  emptyCategories: messages.merchandise.emptyCategories,
}
---

<BaseLayout
  locale={locale}
  title={messages.merchandise.pageTitle}
  description={messages.merchandise.pageDescription}
  canonicalPath={localizedPath('/merchandise', locale)}
>
  <main class="relative isolate min-h-screen">
    <div
      class="absolute inset-0 -z-20 bg-cover bg-fixed bg-center"
      style={`background-image: url(${bgImage})`}
    >
    </div>
    <div class="absolute inset-0 -z-10 bg-[#0C381E]/80 mix-blend-multiply"></div>
    <div
      class="absolute inset-x-0 top-0 -z-10 h-[50vh] bg-gradient-to-b from-[#0C381E]/60 to-transparent"
    >
    </div>

    <div class="relative z-10 w-full">
      <MerchandiseHeroSection data={data} locale={locale} />
      <MerchandiseCatalog
        client:load
        products={products}
        categories={categoryCounts}
        filterLabels={filterLabels}
        emptyProductsMessage={messages.merchandise.emptyProducts}
      />
    </div>
  </main>
</BaseLayout>

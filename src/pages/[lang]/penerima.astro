---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { BeneficiarySection } from '#/components/beneficiary-section'
import {
  getLangStaticPaths,
  getMessages,
  localizedPath,
  resolveLocale,
} from '#/lib/i18n'
import { normalizeStrapiMediaUrl } from '#/lib/strapi/client'
import { getPenerimaPage } from '#/lib/strapi/pages'

export function getStaticPaths() {
  return getLangStaticPaths()
}

const locale = resolveLocale(Astro.params.lang)
const messages = getMessages(locale)
const payload = await getPenerimaPage({ locale })
const data = payload.data ?? undefined

const bgImage =
  normalizeStrapiMediaUrl(data?.heroBackground?.url) || '/garda-hero-reference.png'
---

<BaseLayout
  locale={locale}
  title={messages.penerima.pageTitle}
  description={messages.penerima.pageDescription}
  canonicalPath={localizedPath('/penerima', locale)}
>
  <main class="relative isolate min-h-screen">
    <div
      class="absolute inset-0 -z-20 bg-cover bg-fixed bg-center"
      style={`background-image: url(${bgImage})`}
    >
    </div>
    <div class="absolute inset-0 -z-10 bg-[#0C381E]/80 mix-blend-multiply"></div>
    <div
      class="absolute inset-x-0 top-0 -z-10 h-[50vh] bg-linear-to-b from-[#0C381E]/60 to-transparent"
    >
    </div>

    <div class="relative z-10 w-full">
      <BeneficiarySection client:load data={data} locale={locale} />
    </div>
  </main>
</BaseLayout>

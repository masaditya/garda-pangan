---
import { AgentChangeSection } from '../components/agent-change-section'
import { AwardsInstagramSection } from '../components/awards-instagram-section'
import { FeaturedBySection } from '../components/featured-by-section'
import { HeroScrollSequence } from '../components/hero-scroll-sequence'
import { SupportersCollaboratorsSection } from '../components/supporters-collaborators-section'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getHomepage } from '../lib/strapi/pages'

const homepageResponse = await getHomepage()
const homepage = homepageResponse?.data
---

<BaseLayout canonicalPath="/">
  <main class="garda-main">
    <HeroScrollSequence
      title={homepage?.heroTitle}
      subtitle={homepage?.heroSubtitle}
      ctaText={homepage?.heroCtaText}
      ctaLink={homepage?.heroCtaLink}
      backgroundImage={homepage?.heroBackground?.url}
      didYouKnowSlides={homepage?.didYouKnow}
      portionsRescued={homepage?.statsPortionsRescued}
      co2Reduced={homepage?.statsCo2Reduced}
      foodLossPotential={homepage?.statsFoodLossPotential}
      foodScrap={homepage?.statsFoodScrap}
      impactStats={homepage?.impactStats}
      client:load
    />
    <FeaturedBySection
      title={homepage?.featuredBy?.title}
      logos={homepage?.featuredBy?.logos?.map((l) => ({
        id: l.id,
        url: l.url,
        name: l.name,
      }))}
      client:visible
    />
    <AgentChangeSection
      title={homepage?.agenPerubahanTitle}
      subtitle={homepage?.agenPerubahanSubtitle}
      cards={homepage?.agenPerubahanCards}
    />
    <SupportersCollaboratorsSection
      title={homepage?.supporterTitle}
      subtitle={homepage?.supporterSubtitle}
      supporters={homepage?.supporterCards}
    />
    <AwardsInstagramSection
      awardTitle={homepage?.awardTitle}
      awards={homepage?.awardCards}
      instagramTitle={homepage?.instagramTitle}
      posts={homepage?.instagramCards}
      client:visible
    />
  </main>
</BaseLayout>

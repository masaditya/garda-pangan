---
import BaseLayout from '../layouts/BaseLayout.astro'
import { ProgramListSection } from '../components/program-list-section'
import {
  formatProgramDescription,
  getProgramThumbnailUrl,
  getPrograms,
  mapProgramToDetailButtons,
} from '../lib/strapi/programs'

const programs = await getPrograms()

const programData = {
  heroDescription:
    'Garda Pangan bermula dari pengalaman salah seorang founder, Dedhy Trunoyudho yang berlatar belakang pengusaha katering pernikahan.',
  programs: programs.map((program) => ({
    title: program.title,
    image: getProgramThumbnailUrl(program.thumbnail),
    description: formatProgramDescription(program.description),
    buttons: mapProgramToDetailButtons(program),
  })),
}
---

<BaseLayout
  title="Program Kami - Garda Pangan"
  description="Program-program Garda Pangan dalam menyelamatkan makanan berlebih."
  canonicalPath="/program"
>
  <main class="garda-main">
    <ProgramListSection
      client:load
      title="Program <br /> Kami"
      description={programData.heroDescription}
      backgroundImage="https://images.unsplash.com/photo-1593113598332-cd288d649433?q=80&w=2070&auto=format&fit=crop"
      programs={programData.programs}
    />
  </main>
</BaseLayout>

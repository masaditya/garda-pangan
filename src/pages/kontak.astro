---
import BaseLayout from '#/layouts/BaseLayout.astro'
import { ContactSection } from '#/components/contact-section'

const bgImage = 'https://images.unsplash.com/photo-1521737711867-e3b97375f902?q=80&w=2070&auto=format&fit=crop' // New community-focused background
---

<BaseLayout 
  title="Hubungi Kami - Garda Pangan"
  description="Ada pertanyaan atau ingin berkolaborasi? Hubungi tim Garda Pangan melalui berbagai kategori layanan kami."
  canonicalPath="/kontak"
>
  <main class="relative isolate min-h-screen bg-garda-paper">
    {/* Full Container Background Image */}
    <div
      class="absolute inset-0 -z-20 bg-cover bg-fixed bg-center"
      style={`background-image: url(${bgImage})`}
    >
    </div>
    
    {/* Dark Overlay - matching reference image depth */}
    <div class="absolute inset-0 -z-10 bg-[#0C381E]/70 mix-blend-multiply"></div>
    
    {/* Top Gradient for header contrast */}
    <div class="absolute inset-x-0 top-0 -z-10 h-[50vh] bg-linear-to-b from-[#0C381E]/60 to-transparent">
    </div>

    <div class="relative z-10 w-full">
      <ContactSection client:load />
    </div>
  </main>
</BaseLayout>

---
import Footer from '../components/Footer'
import Header from '../components/Header'
import '../styles.css'
import { DEFAULT_LOCALE, getMessages, resolveLocale, type Locale } from '#/lib/i18n'
import { getGlobal } from '#/lib/strapi/global'
import { normalizeStrapiMediaUrl } from '#/lib/strapi/client'

type Props = {
  title?: string
  description?: string
  canonicalPath?: string
  ogImage?: string
  locale?: Locale
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  locale: localeProp,
} = Astro.props

const locale = localeProp ?? resolveLocale(Astro.params.lang)
const messages = getMessages(locale)

const globalResponse = await getGlobal()
const global = globalResponse?.data

const pageTitle = title ?? global?.defaultSeo?.metaTitle ?? messages.meta.defaultTitle
const pageDescription = description ?? global?.defaultSeo?.metaDescription ?? messages.meta.defaultDescription
const pageOgImage = ogImage ?? normalizeStrapiMediaUrl(global?.defaultSeo?.shareImage?.url) ?? undefined
const faviconUrl = normalizeStrapiMediaUrl(global?.favicon?.url)

const currentPath = Astro.url.pathname
const canonicalUrl =
  canonicalPath && Astro.site ? new URL(canonicalPath, Astro.site) : undefined
const themeInitScript = `(function(){try{var stored=window.localStorage.getItem('theme');var mode=(stored==='light'||stored==='dark'||stored==='auto')?stored:'auto';var prefersDark=window.matchMedia('(prefers-color-scheme: dark)').matches;var resolved=mode==='auto'?(prefersDark?'dark':'light'):mode;var root=document.documentElement;root.classList.remove('light','dark');root.classList.add(resolved);root.classList.add('js');if(mode==='auto'){root.removeAttribute('data-theme')}else{root.setAttribute('data-theme',mode)}root.style.colorScheme=resolved;}catch(e){}})();`
---

<!doctype html>
<html lang={locale} suppressHydrationWarning>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {faviconUrl && <link rel="icon" type="image/png" href={faviconUrl} />}
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl.toString()} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {pageOgImage && <meta property="og:image" content={pageOgImage} />}
    <script is:inline set:html={themeInitScript}></script>
  </head>
  <body class="font-sans antialiased [overflow-wrap:anywhere] selection:bg-[rgba(79,184,178,0.24)]">
    <Header currentPath={currentPath} locale={locale} client:load />
    <slot />
    <Footer
      currentPath={currentPath}
      locale={locale}
      address={global?.footerAddress}
      phone={global?.footerPhone}
      email={global?.footerEmail}
      socialLinks={global?.footerSocialLinks}
    />
    <script>
      function initScrollReveal() {
        const reveals = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.05,
            rootMargin: '0px 0px -40px 0px',
          }
        );

        reveals.forEach((el) => {
          observer.observe(el);
        });
      }

      initScrollReveal();
      document.addEventListener('astro:page-load', initScrollReveal);
      document.addEventListener('astro:after-swap', initScrollReveal);
    </script>
  </body>
</html>
